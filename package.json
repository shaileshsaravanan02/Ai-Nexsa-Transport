{
  "name": "transport-bi-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@transport-bi/web",
    "dev:server": "npm run dev --workspace=@transport-bi/server",
    "dev:mobile": "npm run start --workspace=@transport-bi/mobile",
    "build:web": "npm run build --workspace=@transport-bi/web",
    "build:server": "npm run build --workspace=@transport-bi/server"
  }
}
